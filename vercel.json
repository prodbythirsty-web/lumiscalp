{
  "version": 2,
  "buildCommand": "",
  "outputDirectory": ".",
  "functions": {
    "api/order.js":           { "memory": 256, "maxDuration": 10 },
    "api/update-shipping.js": { "memory": 256, "maxDuration": 10 },
    "api/webhook.js":         { "memory": 256, "maxDuration": 10 }
  },
  "routes": [
    { "src": "/api/order",           "dest": "/api/order.js"           },
    { "src": "/api/update-shipping", "dest": "/api/update-shipping.js" },
    { "src": "/api/webhook",         "dest": "/api/webhook.js"         },
    { "src": "/checkout",            "dest": "/checkout.html"          },
    { "src": "/checkout.html",       "dest": "/checkout.html"          },
    { "src": "/",                    "dest": "/index.html"             },
    { "src": "/(.*\\.(css|js|jpg|jpeg|png|gif|svg|ico|webp|woff|woff2|ttf))", "dest": "/$1" }
  ]
}
